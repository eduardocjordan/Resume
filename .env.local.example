# Copy this file to .env.local for local development. In production (Vercel), set these
# under Project Settings -> Environment Variables instead — see the deploy walkthrough doc.
# Never commit the real .env.local file (it's already gitignored).

# Claude API key — from console.anthropic.com. Used server-side only (chat replies + summaries).
ANTHROPIC_API_KEY=

# Supabase project credentials — from your Supabase project's Settings -> API page.
# SUPABASE_SERVICE_ROLE_KEY is a privileged secret: server-side only, never in client code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email) — from resend.com dashboard.
RESEND_API_KEY=
# Must be an address on a domain you've verified with Resend.
RESEND_FROM_EMAIL=
# Where session summary emails get sent — almost certainly Eduardo's own inbox.
OWNER_NOTIFICATION_EMAIL=

# A random string you make up yourself (e.g. a long password). Vercel automatically sends it
# back as the Authorization header when it triggers the daily cron job, so the cron endpoint
# can confirm the request really came from Vercel and not a random visitor hitting the URL.
CRON_SECRET=

# Optional: target compensation band for the salary guardrail. If left unset, the bot will
# never claim a figure is "below" or "aligned" — it just won't be able to do that comparison.
# Eduardo needs to supply real numbers here before this is fully load-bearing.
TARGET_COMP_MIN=
TARGET_COMP_MAX=
TARGET_COMP_CURRENCY=USD

# Optional cost controls — sensible defaults are used if left unset.
CHAT_MESSAGE_CAP=20
CHAT_DAILY_SPEND_CEILING_USD=2.00
